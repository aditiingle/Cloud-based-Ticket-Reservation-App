<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_rounded_input"
    android:padding="16dp">

    <!-- Image placeholder -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imgContainer"
        android:layout_width="80dp"
        android:layout_height="80dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">
        <ImageView
            android:id="@+id/ivEventImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#D1D5DB"
            android:scaleType="centerCrop" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvEventCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sports"
        android:textColor="#5A55EE"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/imgContainer"
        app:layout_constraintStart_toEndOf="@id/imgContainer" />

    <TextView
        android:id="@+id/tvEventName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Super Bowl LX"
        android:textColor="#161C2D"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvEventCategory"
        app:layout_constraintStart_toStartOf="@id/tvEventCategory"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Assume location and date can be placed here -->
    <TextView
        android:id="@+id/tvEventDateTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Feb 7"
        android:textColor="#6E7381"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvEventName"
        app:layout_constraintStart_toStartOf="@id/tvEventCategory" />

    <!-- Optional location text -->
    <TextView
        android:id="@+id/tvEventLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Santa Clara"
        android:textColor="#6E7381"
        android:textSize="12sp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvEventName"
        app:layout_constraintStart_toEndOf="@id/tvEventDateTime" />

    <TextView
        android:id="@+id/tvEventPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="$450"
        android:textColor="#161C2D"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/imgContainer"
        app:layout_constraintStart_toStartOf="@id/tvEventCategory" />

</androidx.constraintlayout.widget.ConstraintLayout>