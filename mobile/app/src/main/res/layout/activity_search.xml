<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Search"
        android:textColor="#161C2D"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Assume bg_rounded_input exists from previous edit -->
    <EditText
        android:id="@+id/etSearch"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_rounded_input"
        android:hint="Search events, locations..."
        android:paddingHorizontal="16dp"
        android:textColor="#161C2D"
        android:textColorHint="#9B9EAC"
        android:textSize="14sp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDatePicker" />

    <ImageView
        android:id="@+id/btnDatePicker"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_rounded_input"
        android:src="@android:drawable/ic_menu_today"
        android:padding="16dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        android:onClick="showDatePickerDialog"
        app:tint="#5A55EE"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Categories Grid -->
    <LinearLayout
        android:id="@+id/categoriesContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/etSearch">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">
            <!-- Category 1 -->
            <TextView
                android:id="@+id/catSearchConcerts"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:background="@drawable/bg_demo_block"
                android:text="Concerts"
                android:textColor="#161C2D"
                android:textStyle="bold"
                android:gravity="center_vertical|start"
                android:paddingStart="16dp"
                android:layout_marginEnd="8dp" />
            <!-- Category 2 -->
            <TextView
                android:id="@+id/catSearchSports"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:background="@drawable/bg_demo_block"
                android:text="Sports"
                android:textColor="#161C2D"
                android:textStyle="bold"
                android:gravity="center_vertical|start"
                android:paddingStart="16dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:baselineAligned="false">
            <!-- Category 3 -->
            <TextView
                android:id="@+id/catSearchMovies"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:background="@drawable/bg_demo_block"
                android:text="Movies"
                android:textColor="#161C2D"
                android:textStyle="bold"
                android:gravity="center_vertical|start"
                android:paddingStart="16dp"
                android:layout_marginEnd="8dp" />
            <!-- Category 4 -->
            <TextView
                android:id="@+id/catSearchTravel"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:background="@drawable/bg_demo_block"
                android:text="Travel"
                android:textColor="#161C2D"
                android:textStyle="bold"
                android:gravity="center_vertical|start"
                android:paddingStart="16dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewSearch"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/categoriesContainer"
        app:layout_constraintBottom_toTopOf="@id/bottomNav" />

    <include
        android:id="@+id/bottomNav"
        layout="@layout/layout_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>