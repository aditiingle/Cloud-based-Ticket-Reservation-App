<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_rounded_input"
    android:paddingTop="20dp"
    android:paddingBottom="16dp">

    <!-- Top Half -->
    <TextView
        android:id="@+id/tvTicketCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sports"
        android:textColor="#5A55EE"
        android:textSize="12sp"
        android:textStyle="bold"
        android:background="@drawable/bg_avatar"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvTicketId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="#RES8641"
        android:textColor="#9B9EAC"
        android:textSize="12sp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toTopOf="@id/tvTicketCategory"
        app:layout_constraintBottom_toBottomOf="@id/tvTicketCategory"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvEventName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Super Bowl LX"
        android:textColor="#161C2D"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvTicketCategory"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/llDateLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvEventName">

        <TextView
            android:id="@+id/tvEventDateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2/7/2026"
            android:textColor="#6E7381"
            android:textSize="12sp"
            android:drawableStart="@android:drawable/ic_menu_today"
            android:drawablePadding="8dp"
            android:drawableTint="#9B9EAC" />

        <TextView
            android:id="@+id/tvEventLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Santa Clara"
            android:textColor="#6E7381"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:drawableStart="@android:drawable/ic_dialog_map"
            android:drawablePadding="8dp"
            android:drawableTint="#9B9EAC" />
    </LinearLayout>

    <!-- Divider Line -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E3EB"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/llDateLocation" />

    <!-- Notches on divider (optional UI flair) -->
    <View
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:background="@drawable/bg_avatar"
        android:backgroundTint="@color/white"
        app:layout_constraintTop_toTopOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="-8dp" />

    <View
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:background="@drawable/bg_avatar"
        android:backgroundTint="@color/white"
        app:layout_constraintTop_toTopOf="@id/divider"
        app:layout_constraintBottom_toBottomOf="@id/divider"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="-8dp" />

    <!-- Bottom Half -->
    <TextView
        android:id="@+id/tvTicketLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tickets"
        android:textColor="#9B9EAC"
        android:textSize="12sp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvTicketQuantityPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1 x $450"
        android:textColor="#161C2D"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTicketLabel"
        app:layout_constraintStart_toStartOf="@id/tvTicketLabel" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCancelTicket"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:background="@drawable/bg_category"
        android:text="Cancel"
        android:textAllCaps="false"
        android:textColor="#161C2D"
        android:textSize="12sp"
        android:layout_marginEnd="20dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="@id/tvTicketLabel"
        app:layout_constraintBottom_toBottomOf="@id/tvTicketQuantityPrice"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>